# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Cassandra ─────────────────────────────────────────────────────────────────
CASSANDRA_HOST=localhost

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_HOST=http://localhost:9200

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER=local[*]

# ── App ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Model ─────────────────────────────────────────────────────────────────────
CHECKPOINT_DIR=checkpoints
